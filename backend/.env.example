# OpenWatch Backend — environment variables
# Copy to .env for local dev. Set all of these in Railway.

# PostgreSQL (provided by Railway)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis (provided by Railway — use the Private URL)
REDIS_URL=redis://:password@host:6379

# ── Security ──────────────────────────────────────────────────────────────────

# API key for dashboard → backend calls.
# Generate: openssl rand -hex 32
# Must match NEXT_PUBLIC_OW_KEY in the dashboard.
DASHBOARD_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed dashboard origins.
# e.g. https://openwatch.vercel.app or https://dashboard.yourdomain.com
DASHBOARD_URL=https://your-dashboard.vercel.app
